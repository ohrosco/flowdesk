# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── TWILIO (SMS) ───────────────────────────────────────────────────────────────
# Get these from: https://twilio.com → Console Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── RESEND (EMAIL) ─────────────────────────────────────────────────────────────
# Get this from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Your Business Name

# ── ANTHROPIC (AI) ────────────────────────────────────────────────────────────
# Get this from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── APP ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_BUSINESS_NAME=FlowDesk

# ── AUTH ──────────────────────────────────────────────────────────────────────
# Password to log in to the dashboard. Set something strong in production.
ADMIN_PASSWORD=change_me_before_deploying
CRON_SECRET=your_cron_secret_here

# ── TWILIO VOICE ─────────────────────────────────────────────────────────────
# Emergency phone number — inbound calls pressing 1 get forwarded here
# E.164 format: +1xxxxxxxxxx
EMERGENCY_PHONE=

# Business hours (24h format, local time)
BUSINESS_OPEN_HOUR=8
BUSINESS_CLOSE_HOUR=18
BUSINESS_TIMEZONE=America/New_York
BUSINESS_HOURS_TEXT=Monday through Friday, 8 AM to 6 PM
BUSINESS_ADDRESS=
BOOKING_URL=

# ── STRIPE (SUBSCRIPTIONS) ─────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → API Keys
STRIPE_SECRET_KEY=